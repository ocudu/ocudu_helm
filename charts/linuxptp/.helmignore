# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.

# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/

# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~

# Various IDEs
.project
.idea/
*.tmproj
.vscode/

# CI/CD files
.gitlab-ci.yml
.gitlab/

# Documentation (not needed in chart package)
CONTRIBUTING.md
OWNERS
OWNERS_ALIASES

# Examples and test data (optional - keep values examples in package)
examples/
test-values/
*.test.yaml

# OS files
.DS_Store
Thumbs.db
